# ── 数据库 ──
POSTGRES_USER=mindtalk
POSTGRES_PASSWORD=请替换为强密码

# ── Redis ──
REDIS_PASSWORD=请替换为强密码

# ── MinIO ──
MINIO_ACCESS_KEY=请替换
MINIO_SECRET_KEY=请替换为强密码
# 对外访问地址（有域名时改为 https://你的域名/storage）
MINIO_PUBLIC_ENDPOINT=http://localhost:9000

# ── JWT（必须修改，生产环境用随机 64 位字符串）──
JWT_SECRET=请替换为强密码

# ── RSS ──
RSS_SITE_URL=http://localhost
RSS_TITLE=MindTalk 最新帖子
RSS_DESCRIPTION=MindTalk 思享论坛最新帖子
RSS_GENERATOR=MindTalk Forum

# ── CORS（有域名后改为具体域名，多个逗号分隔）──
CORS_ALLOWED_ORIGINS=*
