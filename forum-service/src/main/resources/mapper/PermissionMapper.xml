<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mindtalk.forum.modules.admin.mapper.PermissionMapper">

    <resultMap id="BaseResultMap" type="com.mindtalk.forum.modules.admin.entity.Permission">
        <id column="id" property="id"/>
        <result column="parent_id" property="parentId"/>
        <result column="perm_name" property="permName"/>
        <result column="perm_code" property="permCode"/>
        <result column="perm_type" property="permType"/>
        <result column="path" property="path"/>
        <result column="icon" property="icon"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <sql id="Base_Column_List">
        p.id, p.parent_id, p.perm_name, p.perm_code, p.perm_type,
        p.path, p.icon, p.sort_order, p.status,
        p.create_time, p.update_time, p.deleted
    </sql>

    <select id="selectByRoleId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM permissions p
        INNER JOIN role_permissions rp ON p.id = rp.permission_id AND rp.deleted = 0
        WHERE rp.role_id = #{roleId}
          AND p.deleted = 0
        ORDER BY p.sort_order
    </select>

</mapper>
